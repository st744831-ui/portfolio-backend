# ============================================================
#  PORTFOLIO ACCESS BACKEND — CONFIGURATION
#  Copy this file to ".env" and fill in YOUR real values.
#  cp .env.example .env
# ============================================================

# ---- Server ----
PORT=4000
NODE_ENV=production

# Public URL where THIS backend is reachable (no trailing slash).
# Used to build the Approve/Reject links inside notification emails.
# e.g. https://api.yourdomain.com  or  https://your-app.onrender.com
BACKEND_PUBLIC_URL=http://localhost:4000

# Public URL where your FRONTEND (the portfolio site) is hosted (no trailing slash).
# Used to build the "View Complete Portfolio" link: <FRONTEND_URL>/work.html?token=xxxx
# e.g. https://yourdomain.com
FRONTEND_PUBLIC_URL=http://localhost:5500

# Comma-separated list of origins allowed to call this API (CORS).
# Include your frontend origin(s). e.g. https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# ---- Secrets (CHANGE THESE — use long random strings) ----
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
ACCESS_TOKEN_SECRET=replace-with-another-long-random-string
CSRF_SECRET=replace-with-a-third-long-random-string

# How long an approved portfolio-access token stays valid.
ACCESS_TOKEN_TTL_DAYS=30

# ---- Admin login (the ONLY account that can reach /admin) ----
# Email you log into the dashboard with.
ADMIN_EMAIL=you@yourdomain.com
# Set ONE of the following:
#  - ADMIN_PASSWORD: plain password (simplest; fine for a single admin)
#  - ADMIN_PASSWORD_HASH: bcrypt-style hash (use `npm run init-admin` to generate)
ADMIN_PASSWORD=change-this-strong-password
# ADMIN_PASSWORD_HASH=

# ---- Where YOU receive notification emails ----
NOTIFY_EMAIL=you@yourdomain.com

# ---- Email provider ----
# One of: resend | smtp | sendgrid | console
#   console  = no real email, just logs to terminal (great for local testing)
EMAIL_PROVIDER=console

# The "From" address shown on outgoing emails. Must be a verified sender/domain.
EMAIL_FROM=Portfolio <noreply@yourdomain.com>

# -- Resend (EMAIL_PROVIDER=resend) --
RESEND_API_KEY=

# -- SendGrid (EMAIL_PROVIDER=sendgrid) --
SENDGRID_API_KEY=

# -- SMTP / Nodemailer (EMAIL_PROVIDER=smtp) --
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
